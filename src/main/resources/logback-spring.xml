<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  DEV / TEST — Consola con colores                                   -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <springProfile name="dev,test,local">

        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>
                    %d{HH:mm:ss.SSS} %highlight(%-5level) %cyan([%15.15thread]) %yellow(%-40.40logger{39}) : %msg%n
                </pattern>
                <charset>UTF-8</charset>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>

        <!-- Aplicación -->
        <logger name="com.fourguard.wms" level="DEBUG" additivity="false">
            <appender-ref ref="CONSOLE"/>
        </logger>

        <!-- SQL (solo en dev, no en test) -->
        <springProfile name="dev,local">
            <logger name="org.hibernate.SQL" level="DEBUG" additivity="false">
                <appender-ref ref="CONSOLE"/>
            </logger>
        </springProfile>

        <!-- Spring Security — INFO para no saturar los logs -->
        <logger name="org.springframework.security" level="INFO" additivity="false">
            <appender-ref ref="CONSOLE"/>
        </logger>

        <!-- Flyway -->
        <logger name="org.flywaydb" level="INFO" additivity="false">
            <appender-ref ref="CONSOLE"/>
        </logger>

    </springProfile>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  PROD — Consola estructurada (JSON-ready)                           -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <springProfile name="prod">

        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{yyyy-MM-dd'T'HH:mm:ss.SSSZ} %-5level [%thread] %logger{36} - %msg%n</pattern>
                <charset>UTF-8</charset>
            </encoder>
        </appender>

        <root level="WARN">
            <appender-ref ref="CONSOLE"/>
        </root>

        <logger name="com.fourguard.wms" level="INFO" additivity="false">
            <appender-ref ref="CONSOLE"/>
        </logger>

        <logger name="org.springframework.security" level="WARN" additivity="false">
            <appender-ref ref="CONSOLE"/>
        </logger>

    </springProfile>

</configuration>
